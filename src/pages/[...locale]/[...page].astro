---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import PostPage from '@components/PostPage.astro';
import PostCard from '@components/PostCard.astro';
import Navi from '@components/control/Navi.astro';
import FabMenu from '@components/control/FabMenu.astro';

import { getBlogEntrySort } from '@utils/content-utils'
import { blogCoverUrl } from '@utils/url-utils'
import { getRelativeLocaleUrl } from '@utils/url-utils';
import { siteConfig, profileConfig } from '@/config';
import { i18n } from "astro:config/client";
import type { CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import i18nit from '@i18n/translation'
import ProjectCard from '@components/ProjectCard.astro';
import goals from '@/data/goals.json';
import projects from '@/data/projects.json';

interface Goal {
  title: string;
  titleEn: string;
  desc: string;
  descEn: string;
}

interface Project {
  name: string;
  description: string;
  descriptionEn?: string;
  githubUrl: string;
  tags: string[];
  status?: string;
}

const { page } = Astro.props;

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const isEn = currentLang === 'en';

export const getStaticPaths = (async ({ paginate }) => {

  function createPinTopSort() {
    return (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => {
      const pinTopA = a.data.pinTop ?? 0;
      const pinTopB = b.data.pinTop ?? 0;
      if (pinTopA > 0 && pinTopB > 0) return pinTopB - pinTopA;
      if (pinTopA > 0) return -1;
      if (pinTopB > 0) return 1;
      return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    };
  }

  const paths = [];
  for (const locale of i18n?.locales ?? []) {
    const localeCode = typeof locale === 'string' ? locale : locale.path;
    const localeParam = localeCode === i18n?.defaultLocale ? undefined : localeCode;
    const blogEntries = await getBlogEntrySort(localeParam, undefined, createPinTopSort());
    const paginatedPaths = paginate(blogEntries, {
      pageSize: siteConfig.pageSize,
      params: { locale: localeParam }
    });
    paths.push(...paginatedPaths);
  }
  return paths;
}) satisfies GetStaticPaths

const isFirstPage = page.currentPage === 1;
const featuredProjects = (projects as Project[]).slice(0, 3);
const pageTitle = `${siteConfig.title} - ${siteConfig.subTitle}`;
const archivesUrl = getRelativeLocaleUrl(currentLang, '/archives/');
const aboutUrl = getRelativeLocaleUrl(currentLang, '/about/');
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <!-- ===== Page 1: Hero Homepage ===== -->
  {
    isFirstPage && (
      <div class="mx-auto w-full max-w-[var(--page-width)]">
        <!-- Hero -->
        <section class="flex flex-col items-center pt-20 pb-16 text-center reveal">
          <img
            src={profileConfig.avatar}
            alt={profileConfig.name}
            class="w-24 h-24 rounded-full object-cover border-2 mb-6"
            style="border-color: var(--button-border-color);"
            onerror="this.style.display='none'"
          />
          <h1
            class="text-4xl font-bold tracking-tight sm:text-5xl"
            style="color: var(--text-color); font-family: 'Playfair Display', serif;"
          >
            {profileConfig.name}
          </h1>
          <p class="mt-4 max-w-lg text-lg leading-relaxed" style="color: var(--text-color-70);">
            {isEn ? profileConfig.intro.en : profileConfig.intro.zh}
          </p>

          <!-- Tags -->
          <ul class="mt-6 flex flex-wrap justify-center gap-2">
            {profileConfig.tags.map((tag: string) => (
              <li
                class="rounded-full border px-3 py-1 text-xs"
                style="border-color: var(--button-border-color); color: var(--text-color-70);"
              >
                {tag}
              </li>
            ))}
          </ul>

          <!-- CTAs -->
          <div class="mt-8 flex gap-4">
            <a
              href={archivesUrl}
              class="rounded-full px-7 py-3 text-sm font-medium transition-all hover:opacity-90"
              style="background: var(--link-color); color: #fcfbf7;"
            >
              {isEn ? 'Read Articles' : '阅读文章'}
            </a>
            <a
              href={aboutUrl}
              class="rounded-full border px-7 py-3 text-sm font-medium transition-all hover:opacity-80"
              style="border-color: var(--button-border-color); color: var(--text-color);"
            >
              {isEn ? 'About Me' : '关于我'}
            </a>
          </div>
        </section>

        <!-- Latest Articles -->
        <section class="mb-8 reveal">
          <div
            class="flex items-end justify-between gap-4 border-b pb-4"
            style="border-color: var(--button-border-color);"
          >
            <h2
              class="text-2xl font-bold"
              style="color: var(--text-color); font-family: 'Playfair Display', serif;"
            >
              {isEn ? 'Articles' : '言集'}
            </h2>
            <a
              href={archivesUrl}
              class="text-sm transition-colors hover:underline"
              style="color: var(--text-color-70);"
            >
              {isEn ? 'View all →' : '全部文章 →'}
            </a>
          </div>
          <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {page.data.slice(0, 3).map((entry: CollectionEntry<'blog'>) => (
              <PostCard
                entry={entry}
                title={entry.data.title}
                description={entry.data.description}
                image={blogCoverUrl(entry.data.image, entry.id)}
                pubDate={entry.data.pubDate}
                url={entry.id}
                fallback={entry.isFallback}
              />
            ))}
          </div>
        </section>

        <!-- Recent Goals -->
        <section class="mb-10 reveal">
          <div
            class="flex items-end justify-between gap-4 border-b pb-4"
            style="border-color: var(--button-border-color);"
          >
            <h2
              class="text-2xl font-bold"
              style="color: var(--text-color); font-family: 'Playfair Display', serif;"
            >
              {isEn ? 'Working' : '耕集'}
            </h2>
          </div>
          <div class="mt-6 grid gap-6 md:grid-cols-3">
            {(goals as Goal[]).map((g) => (
              <article
                class="flex flex-col rounded-xl border p-5 transition-all duration-300"
                style="border-color: var(--button-border-color); background: var(--bg-color);"
              >
                <h3
                  class="text-lg font-semibold"
                  style="color: var(--text-color); font-family: 'Playfair Display', serif;"
                >
                  {isEn ? g.titleEn : g.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed" style="color: var(--text-color-70);">
                  {isEn ? g.descEn : g.desc}
                </p>
              </article>
            ))}
          </div>
        </section>

        <!-- Featured Projects -->
        <section class="mb-10 reveal">
          <div
            class="flex items-end justify-between gap-4 border-b pb-4"
            style="border-color: var(--button-border-color);"
          >
            <h2
              class="text-2xl font-bold"
              style="color: var(--text-color); font-family: 'Playfair Display', serif;"
            >
              {isEn ? 'Projects' : '栈集'}
            </h2>
            <a
              href={getRelativeLocaleUrl(currentLang, '/projects/')}
              class="text-sm transition-colors hover:underline"
              style="color: var(--text-color-70);"
            >
              {isEn ? 'All projects →' : '全部项目 →'}
            </a>
          </div>
          <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredProjects.map((p) => (
              <ProjectCard {...p} lang={currentLang} />
            ))}
          </div>
        </section>

        <!-- Divider -->
        <div class="mb-8 border-t" style="border-color: var(--button-border-color);"></div>
      </div>
    )
  }

  <!-- ===== Page 2+: Simple blog list ===== -->
  {
    !isFirstPage && (
      <div class="mx-auto w-full max-w-[var(--page-width)] pt-12">
        <h2
          class="mb-6 text-2xl font-bold"
          style="color: var(--text-color); font-family: 'Playfair Display', serif;"
        >
          {isEn ? 'Articles' : '言集'}
        </h2>
      </div>
    )
  }

  {
    !isFirstPage && (
      <>
        <PostPage page={page} />
        <Navi page={page} />
      </>
    )
  }
  <FabMenu showBackBottom={true} />
</MainPageLayout>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal-up 0.6s ease-out forwards;
  }
  .reveal:nth-child(2) { animation-delay: 0.1s; }
  .reveal:nth-child(3) { animation-delay: 0.2s; }
  .reveal:nth-child(4) { animation-delay: 0.3s; }

  @keyframes reveal-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
